{
  "version": 2,
  "builds": [
    {
      "src": "backend/mock_api.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/mock_api.py"
    },
    {
      "src": "/(.*)",
      "use": "@vercel/static",
      "dest": "frontend/dist/$1"
    }
  ]
}
